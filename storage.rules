rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /avatars/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /covers/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /posts/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /announcements/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /events/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /conversations/{conversationId}/{allPaths=**} {
      allow read: if request.auth != null; // Ideally check if user is a participant
      allow write: if request.auth != null;
    }
    // 🛡️ [PDPL 2026] Guardian ID uploads — only the authenticated minor can write their own record
    match /guardian_ids/{allPaths=**} {
      allow read: if request.auth != null && (
        request.auth.token.role == 'admin' || 
        request.auth.token.role == 'management'
      );
      allow write: if request.auth != null && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
    }
    // 📸 Broadcast statuses — authenticated users only
    match /stories/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // 🎬 Private vault recordings
    match /recordings/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // 🎙️ Homii voice notes — only the owner can write
    match /homii_notes/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
