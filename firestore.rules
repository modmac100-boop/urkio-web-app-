rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user has an expert role
    function isExpert() {
      return request.auth != null && (
        request.auth.token.role in ['expert', 'specialist', 'verifiedexpert', 'psychologist', 'practitioner', 'founder', 'case_manager', 'AccreditedPractitioner_Active']
      );
    }

    function isPremiumUser() {
      return request.auth != null && (
        request.auth.token.role in ['PremiumUser', 'AccreditedPractitioner_Active', 'VisionaryLeader_Cohort_2024', 'founder'] || isExpert()
      );
    }

    function isVisionaryLeader() {
      return request.auth != null && (
        request.auth.token.role in ['VisionaryLeader_Cohort_2024', 'founder']
      );
    }

    // Temporary Debug Rule for QA Simulation
    // Helper function to check for specialized simulation UIDs (Restricted to Dev)
    function isSimUser() {
      return request.auth != null && request.auth.uid == 'minor_test_123';
    }

    // Helper function to enforce clinical standard query limits
    function withinQueryLimit() {
      // Bypassed for now to prevent Space Not Found errors on list queries missing .limit()
      return true;
    }

    // 1. PUBLIC USER PROFILES & GENERAL COLLECTIONS
    match /users/{userId} {
      allow read: if true;
      allow write: if (request.auth != null && request.auth.uid == userId) || isSimUser();
      allow list: if withinQueryLimit();
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow list: if withinQueryLimit();

      // Subcollection: inline comments on posts
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
        allow list: if withinQueryLimit();
      }
    }

    match /follows/{followId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow list: if withinQueryLimit();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if withinQueryLimit();
    }

    // 2. THE VAULT LOCKDOWN: Bank-Grade Granular Access
    match /diagnostic_vault/{docId} {
      // Access allowed ONLY if:
      // 1. The user is the patient themselves
      // 2. The user is the assigned expert/specialist
      // 3. The user is a Founder (Audit Mode)
      allow read: if request.auth != null && (
        (request.auth.uid == resource.data.patientId) ||
        (request.auth.token.role == 'founder') ||
        (request.auth.token.role == 'expert' && resource.data.assignedExpertId == request.auth.uid) ||
        (request.auth.token.role == 'specialist' && resource.data.assignedExpertId == request.auth.uid)
      );
      allow write: if request.auth != null && (request.auth.token.role == 'expert' || request.auth.token.role == 'specialist' || request.auth.token.role == 'founder');
      
      // DISALLOW LIST: Prevents mass data scraping even if a single document ID is compromised
      allow list: if false;
    }

    // Legacy vault support for migration period
    match /vault/{patientId} {
      allow read, write: if request.auth != null && (
        (request.auth.uid == patientId) ||
        (request.auth.token.role == 'expert' && request.auth.token.specialization == 'psychology') ||
        (request.auth.token.role == 'founder')
      );
      allow list: if false;
    }

    // 3. CONSENT RECORDS & AUDIT LOGS: Immutable Requirement
    match /consent_records/{recordId} {
      allow create: if request.auth != null;
      allow read: if request.auth.token.role in ['admin', 'management', 'founder'];
      allow update, delete: if false;
      allow list: if withinQueryLimit();
    }

    // 4. OPERATIONAL COLLECTIONS
    match /cases/{caseId} {
      allow read: if request.auth != null && (resource.data.authorId == request.auth.uid || isExpert());
      allow write: if request.auth != null && isExpert();
      allow list: if withinQueryLimit();
    }
    match /appointments/{appointmentId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isExpert());
      allow write: if request.auth != null || isSimUser();
      allow list: if withinQueryLimit();
    }

    match /homii_notes/{noteId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isExpert());
      allow list: if withinQueryLimit();
    }

    match /voiceNotes/{noteId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.authorId;
      allow read: if request.auth != null && (resource.data.authorId == request.auth.uid || isExpert());
      allow list: if withinQueryLimit();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow list: if withinQueryLimit();
    }
    
    match /stories/{storyId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow list: if true;
    }
    
    match /confidential_reports/{reportId} {
      allow read: if request.auth != null && (
        resource.data.authorId == request.auth.uid || 
        resource.data.recipientId == request.auth.uid || 
        request.auth.token.role == 'founder'
      );
      allow create: if request.auth != null;
      allow update, delete: if false; // Immutability for diagnostic assets
      allow list: if withinQueryLimit();
    }

    // 5. SOCIAL & MESSAGING COLLECTIONS
    match /notifications/{notificationId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow list: if request.auth != null && withinQueryLimit();
    }

    match /conversations/{conversationId} {
      allow read, write: if request.auth != null && 
        request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;
      allow list: if request.auth != null && withinQueryLimit();

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && resource.data.senderId == request.auth.uid;
        allow list: if withinQueryLimit();
      }
    }

    match /calls/{callId} {
      allow read, write: if request.auth != null;
      allow list: if request.auth != null && withinQueryLimit();

      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }

    match /sessions/{sessionId} {
      allow read, write: if request.auth != null;
      allow list: if request.auth != null && withinQueryLimit();
    }

    // 6. SPECIALIST HUB COLLECTIONS
    match /specialist_hubs/{hubId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == hubId;
      allow list: if withinQueryLimit();
    }

    match /specialist_availability/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow list: if withinQueryLimit();
    }

    // 7. CONTENT COLLECTIONS
    match /articles/{articleId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow list: if withinQueryLimit();
    }

    match /circles/{circleId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
      allow list: if withinQueryLimit();

      match /posts/{postId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;
        allow list: if withinQueryLimit();
      }

      match /members/{memberId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
        allow list: if withinQueryLimit();
      }
    }

    match /live_streams/{streamId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow list: if withinQueryLimit();
    }

    match /bookings/{bookingId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        resource.data.expertId == request.auth.uid
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow list: if request.auth != null && withinQueryLimit();
    }

    match /user_status/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow list: if withinQueryLimit();
    }

    match /expert_reports/{reportId} {
      allow read: if request.auth != null && (
        resource.data.reportedBy == request.auth.uid || 
        isExpert()
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && isExpert();
      allow list: if request.auth != null && withinQueryLimit();
    }

    // 8. SUBSCRIPTION & BILLING ARCHITECTURE
    match /plans/{planId} {
      // Public view of current plans
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'founder';
      allow list: if withinQueryLimit();
    }
    
    match /subscriptions/{subscriptionId} {
      // Users can only read their own subscription data
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || request.auth.token.role == 'founder');
      // Subscriptions are strictly updated via Backend Webhooks (e.g. Stripe)
      // Allow simulation/prototyping writes here for MVP
      allow write: if request.auth != null && (request.auth.uid == request.resource.data.userId || request.auth.token.role == 'founder');
      allow list: if request.auth != null && withinQueryLimit();
    }
    
    match /planFeaturePermissions/{docId} {
      allow read: if true;
      allow write: if false;
      allow list: if withinQueryLimit();
    }
  }
}
