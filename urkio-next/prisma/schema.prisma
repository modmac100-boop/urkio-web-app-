generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// User & Role Management
// ------------------------------------------------------
enum Role {
  USER
  EXPERT
  ADMIN
}

model User {
  id             String    @id @default(cuid()) // Synced with Clerk User ID
  email          String    @unique
  userCode       String?   @unique
  role           Role      @default(USER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  profile        Profile?
  posts          Post[]
  comments       Comment[]
  appointmentsAsExpert   Appointment[] @relation("ExpertAppointments")
  appointmentsAsUser     Appointment[] @relation("UserAppointments")
  enrollments    Enrollment[]
}

model Profile {
  id               String  @id @default(cuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  displayName      String
  bio              String?
  avatarUrl        String? // Cloudinary/S3 URL
  
  // Expert specific fields
  specialties      String[]
  isVerified       Boolean @default(false)
  licenseNumber    String?
  hourlyRate       Float?
}

// ------------------------------------------------------
// Social Networking
// ------------------------------------------------------
model Post {
  id        String    @id @default(cuid())
  content   String
  mediaUrl  String?
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  
  comments  Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ------------------------------------------------------
// Booking & Appointments
// ------------------------------------------------------
enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Appointment {
  id        String   @id @default(cuid())
  expertId  String
  expert    User     @relation("ExpertAppointments", fields: [expertId], references: [id])
  userId    String
  user      User     @relation("UserAppointments", fields: [userId], references: [id])
  
  date      DateTime
  duration  Int      // in minutes
  status    AppointmentStatus @default(PENDING)
  price     Float
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ------------------------------------------------------
// Educational Courses
// ------------------------------------------------------
model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  price       Float
  thumbnail   String?
  expertId    String
  createdAt   DateTime @default(now())
  
  modules     Module[]
  enrollments Enrollment[]
}

model Module {
  id        String   @id @default(cuid())
  title     String
  videoUrl  String
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order     Int
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
}
